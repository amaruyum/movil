{
  "expo": {
    "name": "listCine",
    "slug": "listcine",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#0D0D0D"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.listcine.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0D0D0D"
      },
      "package": "com.listcine.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
  "expo-router",
  "./plugins/withAndroidGradle",
  [
    "expo-build-properties",
    {
      "android": {
        "kotlinVersion": "2.0.21"
      }
    }
  ]
],
    "scheme": "listcine",
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "23964cf4-8747-4d56-85bc-486079010abe"
      }
    }
  }
}
